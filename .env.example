# Required: absolute path to the project root to search in
PROJECT_SEARCH_ROOT=/path/to/your/project

# Optional: comma-separated list of directory names to exclude
# PROJECT_SEARCH_EXCLUDE_DIRS=vendor,node_modules,.git,var,web

# Optional: default max results returned by grep_code
# PROJECT_SEARCH_MAX_RESULTS=50

# Optional: comma-separated file extensions to include in searches
# PROJECT_SEARCH_EXTENSIONS=php,js,ts,twig,yaml,scss
